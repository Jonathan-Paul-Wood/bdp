{
  "manifest_version": 2,
  "name": "Bias Detection Panel",
  "version": "0.1.0",
  "description": "A Firefox WebExtension to help you detect bias.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "browser_action": {
    "default_title": "Bias Detection Panel",
    "default_icon": "icons/bdp-logo.png"
  },
  "sidebar_action": {
    "default_title": "Bias Detection Panel",
    "default_panel": "panel/panel.html",
    "default_icon": "icons/bdp-logo.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bias-detection-panel@example.local",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["./scripts/read-page-content.js"]
    }
  ]
}
